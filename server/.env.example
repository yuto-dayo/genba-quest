SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
PORT=4001
# Comma-separated list of allowed browser origins. In development, localhost origins are
# accepted automatically when this is left unset.
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Proposal atomic RPC fallback mode
# allow (default): RPC unavailable時に従来フローへフォールバック
# disabled: RPC必須。未適用環境では ATOMIC_RPC_REQUIRED を返す
PROPOSAL_RPC_FALLBACK_MODE=allow

# Production organization creation mode.
# allowlist (default): only emails listed in ORG_BOOTSTRAP_ALLOWED_EMAILS can create an org.
# authenticated: any signed-in user with an email can create their first org.
ORG_CREATION_MODE=allowlist

# Production organization creation allowlist.
# Used when ORG_CREATION_MODE=allowlist.
# Example: ORG_BOOTSTRAP_ALLOWED_EMAILS=owner@example.com,admin@example.com
ORG_BOOTSTRAP_ALLOWED_EMAILS=

# AI Provider Settings
# Default AI provider: gemini | openai | anthropic
AI_PROVIDER=gemini

# ============================================================
# Gmail自動クエスト生成 (Phase 0)
# ============================================================

# Google OAuth認証情報
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REFRESH_TOKEN=your_google_refresh_token_here

# Google Cloud Pub/Sub Topic
# 例: projects/genba-quest-production/topics/gmail-notifications
GOOGLE_PUBSUB_TOPIC=projects/YOUR_PROJECT_ID/topics/gmail-notifications

# Google Cloud Project ID（オプション）
GOOGLE_CLOUD_PROJECT_ID=your_project_id_here

# Site inference monitoring thresholds
GMAIL_SITE_INFERENCE_MIN_SCORE=90
GMAIL_SITE_INFERENCE_TOP_MATCH_LIMIT=3

# ============================================================
# Google Drive attachment storage
# ============================================================

# Drive root folder id (shared with service account)
GOOGLE_DRIVE_ROOT_FOLDER_ID=your_drive_root_folder_id_here

# Dedicated Drive refresh token (recommended for drive scope separation)
# Fallback: if unset, GOOGLE_REFRESH_TOKEN is used.
GOOGLE_DRIVE_REFRESH_TOKEN=your_google_drive_refresh_token_here

# Service account credentials for Drive API
# Either GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON / GOOGLE_SERVICE_ACCOUNT_JSON
# (raw JSON or base64-encoded JSON), or split email/private key vars.
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON={"client_email":"service-account@project.iam.gserviceaccount.com","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"}
# GOOGLE_DRIVE_SERVICE_ACCOUNT_EMAIL=service-account@project.iam.gserviceaccount.com
# GOOGLE_DRIVE_SERVICE_ACCOUNT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
