SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
PORT=4001

# AI Provider Settings
# Default AI provider: gemini | openai | anthropic
AI_PROVIDER=gemini

# ============================================================
# Gmail自動クエスト生成 (Phase 0)
# ============================================================

# Google OAuth認証情報
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REFRESH_TOKEN=your_google_refresh_token_here

# Google Cloud Pub/Sub Topic
# 例: projects/genba-quest-production/topics/gmail-notifications
GOOGLE_PUBSUB_TOPIC=projects/YOUR_PROJECT_ID/topics/gmail-notifications

# Google Cloud Project ID（オプション）
GOOGLE_CLOUD_PROJECT_ID=your_project_id_here
