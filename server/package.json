{
    "name": "genba-quest-server",
    "version": "1.0.0",
    "description": "GENBA QUEST Backend Server",
    "main": "dist/index.js",
    "scripts": {
        "dev": "NODE_ENV=development nodemon --watch src --ext ts --exec \"ts-node src/index.ts\"",
        "typecheck": "tsc --noEmit",
        "lint": "tsc --noEmit",
        "build": "tsc",
        "start": "node dist/index.js",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:integration": "RUN_DB_INTEGRATION_TESTS=1 jest --runInBand --testPathPatterns=src/__tests__/integration/",
        "test:integration:path-module": "RUN_DB_INTEGRATION_TESTS=1 jest --runInBand --runTestsByPath src/__tests__/integration/pathModuleRoute.integration.test.ts",
        "test:integration:proposal-core": "RUN_DB_INTEGRATION_TESTS=1 jest --runInBand --runTestsByPath src/__tests__/integration/executeProposalAtomic.integration.test.ts src/__tests__/integration/executeProposalAtomicAssignment.integration.test.ts src/__tests__/integration/executeProposalAtomicLeaveRequest.integration.test.ts src/__tests__/integration/webhookIntegrationProposalPath.integration.test.ts",
        "cleanup:demo-data": "ts-node src/scripts/cleanup-demo-data.ts",
        "cleanup:invalid-void-chains": "ts-node src/scripts/cleanup-invalid-void-chains.ts",
        "gmail:refresh-token": "ts-node src/scripts/generate-gmail-refresh-token.ts",
        "drive:refresh-token": "ts-node src/scripts/generate-drive-refresh-token.ts",
        "verify:a1-migration": "ts-node src/scripts/verify-a1-migration.ts",
        "verify:a1-health": "ts-node src/scripts/verify-a1-health.ts",
        "verify:beta-mvp": "ts-node src/scripts/verify-beta-mvp-gates.ts",
        "verify:gmail-manual-e2e": "ts-node src/scripts/verify-gmail-manual-e2e.ts",
        "seed:money-e2e": "ts-node src/scripts/seed-money-approval-e2e.ts",
        "seed:path-vertical-slice": "ts-node src/scripts/seed-path-vertical-slice.ts"
    },
    "type": "commonjs",
    "dependencies": {
        "@anthropic-ai/sdk": "^0.71.2",
        "@google/generative-ai": "^0.24.1",
        "@supabase/supabase-js": "^2.89.0",
        "cors": "^2.8.5",
        "dotenv": "^17.2.3",
        "express": "^5.1.0",
        "express-rate-limit": "^8.5.2",
        "googleapis": "^144.0.0",
        "helmet": "^8.1.0",
        "openai": "^6.17.0",
        "puppeteer": "^24.40.0"
    },
    "devDependencies": {
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.5",
        "@types/jest": "^30.0.0",
        "@types/node": "^24.10.0",
        "jest": "^30.2.0",
        "nodemon": "^3.1.10",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3"
    }
}
