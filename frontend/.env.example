# Local development auth is disabled automatically when this points to a remote host.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your_local_supabase_anon_key_here
VITE_API_PROXY_TARGET=http://localhost:4001
# Optional when the browser must call a different origin directly:
# VITE_API_URL=https://api.example.com
# Leave VITE_API_URL unset for same-origin production deploys where Express serves frontend/dist.
