#!/usr/bin/env bash
set -euo pipefail

if [[ "${SKIP_HANDOFF_GUARD:-}" == "1" ]]; then
  if [[ -z "${SKIP_HANDOFF_REASON:-}" ]]; then
    echo "SKIP_HANDOFF_GUARD=1 requires SKIP_HANDOFF_REASON." >&2
    exit 1
  fi
  echo "Handoff guard bypassed: ${SKIP_HANDOFF_REASON}" >&2
  exit 0
fi

staged_files="$(git diff --cached --name-only --diff-filter=ACMR)"
if [[ -z "$staged_files" ]]; then
  exit 0
fi

handoff_markdown_regex='^(HANDOFF\.md$|handoff/.+\.md$)'

# handoff運用ファイル以外に差分があるか
requires_handoff="$(printf '%s\n' "$staged_files" | rg -v '^(HANDOFF\.md$|handoff/|\.githooks/|scripts/session/|\.session/)' || true)"

if [[ -z "$requires_handoff" ]]; then
  exit 0
fi

if ! printf '%s\n' "$staged_files" | rg -q "$handoff_markdown_regex"; then
  echo "Commit blocked: handoff markdown (HANDOFF.md or handoff/**/*.md) must be staged with non-handoff changes." >&2
  echo "Run: scripts/session/session-update.sh --done \"...\" --next \"...\" --validation \"...\"" >&2
  exit 1
fi

if [[ ! -f ".session/active_session" ]]; then
  echo "Commit blocked: no active session marker (.session/active_session)." >&2
  echo "Run: scripts/session/session-start.sh --agent <codex|claude>" >&2
  exit 1
fi

exit 0
